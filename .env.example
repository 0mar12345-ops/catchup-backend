PORT=8080
GIN_MODE=debug
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=gclass

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/api/users/oauth/google/callback
GOOGLE_OAUTH_STATE=gclass-ai-state
FRONTEND_URL=http://localhost:3000

# OpenAI Configuration
OPENAI_API_KEY=sk-...

# Supadata API (YouTube transcript extraction - works on cloud servers)
# Get your key at: https://supadata.ai
SUPADATA_API_KEY=sd_...

# JWT Configuration
JWT_SECRET=your-secret-key-change-this
JWT_COOKIE_NAME=gclass_token
JWT_EXPIRY_HOURS=24

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000
